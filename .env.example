# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GSL Portal

# Email (Resend) — optional, notifications disabled if not set
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=GSL Portal <noreply@gsl.lu>

# Webhooks — optional, notifications disabled if not set
# Get Slack webhook: https://api.slack.com/messaging/webhooks
# Get Teams webhook: https://learn.microsoft.com/en-us/microsoftteams/platform/webhooks-and-connectors/how-to/add-incoming-webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx
